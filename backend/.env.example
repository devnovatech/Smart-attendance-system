PORT=5000
NODE_ENV=development

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting (requests per IP per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# WhatsApp Cloud API (Meta) — sends attendance reports to guardians.
# Create an app at https://developers.facebook.com, add "WhatsApp" product, copy the
# temporary token + phone number ID from the Getting Started panel.
# For production, generate a permanent system-user access token.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
# Name of a pre-approved message template in WhatsApp Business Manager.
# Template body must expect 4 text parameters, in this order:
#   {{1}} = student name, {{2}} = subject, {{3}} = date, {{4}} = status
# Leave blank to send free-form text (only works inside the 24h session window — dev only).
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en_US
# Prepended to guardian phone numbers that don't include a country code (digits only, no '+').
WHATSAPP_DEFAULT_COUNTRY_CODE=91
